{
  "name": "create-scaffold-cli",
  "version": "1.0.0",
  "description": "TUI tool to scaffold Vite/Next.js frontend and MERN backend projects",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "bin": {
    "create-scaffold": "./bin/create-scaffold.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "run": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.mjs\" \"scripts/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "prepare": "husky",
    "ci": "pnpm install --frozen-lockfile && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run knip && pnpm test -- --coverage",
    "lint:fix": "eslint src/ --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"bin/**/*.mjs\" \"scripts/**/*.js\"",
    "knip": "knip",
    "fallow": "fallow",
    "semgrep": "semgrep scan --config auto .",
    "audit": "pnpm audit --audit-level=high",
    "commit": "cz",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "chalk": "^5.3.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@fallow-cli/fallow-node": "3.2.0",
    "@sentry/node": "10.64.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "22.20.0",
    "@types/validator": "^13.11.0",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "knip": "6.25.0",
    "lint-staged": "17.0.8",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.mjs": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
