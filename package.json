{
  "name": "create-scaffold-cli",
  "version": "1.0.0",
  "description": "TUI tool to scaffold Vite/Next.js frontend and MERN backend projects",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "bin": {
    "create-scaffold": "./bin/create-scaffold.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "run": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "prepare": "pnpm run typecheck && pnpm run lint",
    "ci": "pnpm install --frozen-lockfile && pnpm run typecheck && pnpm run lint && pnpm test -- --coverage"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "chalk": "^5.3.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "22.20.0",
    "@types/validator": "^13.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
