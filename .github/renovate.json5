{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":separateMajorDev",
    ":groupPatchMinor",
    ":preserveSemverRanges",
    "schedule:weekly",
  ],
  labels: ["dependencies"],
  rangeStrategy: "bump",
  lockFileMaintenance: { enabled: true },
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
    },
    {
      matchDepTypes: ["devDependencies"],
      automerge: true,
    },
  ],
}